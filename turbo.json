{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test": {},
    "prisma:generate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "seed": {
      "cache": false,
      "dependsOn": ["db:push"]
    }
  }
}
