{
  "name": "vladi-cars",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "test": "turbo test",
    "prisma:generate": "turbo prisma:generate",
    "db:push": "turbo db:push",
    "seed": "pnpm --filter @vladi-cars/catalog seed && pnpm --filter @vladi-cars/orders seed",
    "start": "echo 'Use docker compose up for production' && exit 1",
    "deploy": "bash infra/deploy.sh"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0"
  },
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["unrs-resolver"]
  }
}
