# ─── Local Development ───

# PostgreSQL
DATABASE_URL="postgresql://vladi:vladi_secret@localhost:5432/vladi_cars"

# JWT secret (use a long random string in production)
JWT_SECRET="vladi-cars-secret-key-dev"

# Service URLs (api-gateway uses these to route to microservices)
CATALOG_URL="http://localhost:3001"
AUTH_URL="http://localhost:3004"
CART_URL="http://localhost:3002"
ORDERS_URL="http://localhost:3003"

# Frontend CORS origin
CORS_ORIGIN="http://localhost:5173"

# Logging (trace, debug, info, warn, error, fatal)
LOG_LEVEL="debug"


# ─── Production (set these via deploy script or .env) ───

# DOMAIN=vladi-cars.ru
# JWT_SECRET=<generate with: openssl rand -hex 64>
# POSTGRES_PASSWORD=<generate with: openssl rand -hex 32>
# LOG_LEVEL=info
